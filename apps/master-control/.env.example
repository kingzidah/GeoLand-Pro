# API base URL (leave empty to use Vite dev proxy at /api)
VITE_API_URL=

# Base URL of apps/web — Master Control links here for the consent-gated
# access-request flow (Request Access creates an OrgAccessRequest; the
# landowner's Approve, and the staff member's Enter/Exit of the impersonation
# session, all happen in apps/web at /access-requests)
VITE_WEB_APP_URL=http://localhost:5173
