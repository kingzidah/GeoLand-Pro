{
  "name": "@geolandpro/api",
  "version": "1.0.0",
  "description": "GeoLand Pro REST API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --watch server.ts --ext ts --exec ts-node server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "node --require ./src/test/setupTestEnv.js --require ts-node/register --test src/middleware/authenticate.test.ts src/middleware/tenant.middleware.test.ts src/validations/organisation.schema.test.ts src/validations/accessRequest.schema.test.ts src/services/impersonationSession.service.test.ts src/services/admin.service.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:seed:simulation": "ts-node prisma/seed-karlsruhe-simulation.ts",
    "prisma:seed:test-roles": "ts-node prisma/seed-test-roles.ts",
    "db:postgis": "ts-node prisma/apply-postgis.ts",
    "db:setup": "npm run prisma:migrate -- --name init && npm run db:postgis && npm run prisma:seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "@prisma/client": "^5.12.0",
    "@turf/turf": "^7.3.5",
    "archiver": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.9",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "puppeteer": "^22.6.0",
    "qrcode": "^1.5.4",
    "resend": "^6.14.0",
    "twilio": "^5.0.4",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@mapbox/vector-tile": "^2.0.5",
    "@types/archiver": "^8.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^4.10.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^9.0.8",
    "nodemon": "^3.1.0",
    "pbf": "^4.0.2",
    "prisma": "^5.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
