# ─── Production environment template ─────────────────────────────────────────
# Copy to .env.production and fill in real values. NEVER commit the filled-in
# file — .env.production is gitignored.
#
# Vars marked (required) are enforced at startup by
# src/config/env.validation.ts when NODE_ENV=production — the server will
# refuse to start if any of them are missing.

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── Database (required) ──────────────────────────────────────────────────────
# PostgreSQL with PostGIS extension enabled
DATABASE_URL=postgresql://user:password@host:5432/geolandpro

# ─── Redis (required) ─────────────────────────────────────────────────────────
# Upstash requires TLS — use the rediss:// connection string from
# Upstash → Connect → ioredis. A redis:// (plaintext) URL connects then closes
# immediately with no error.
REDIS_URL=rediss://host:6379

# ─── JWT (required) ────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-64-byte-hex-string-access
JWT_REFRESH_SECRET=replace-with-64-byte-hex-string-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption (required) ─────────────────────────────────────────────────────
# 32-byte (AES-256) key — used for field-level encryption of sensitive data
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-32-byte-hex-string

# ─── Field encryption / OTP salts (required) ───────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HASH_SALT=replace-with-32-byte-hex-string
OTP_SALT=replace-with-32-byte-hex-string

# ─── AWS S3 (required) ─────────────────────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=replace-with-production-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-production-secret-access-key
AWS_S3_BUCKET=geolandpro-documents-prod

# ─── Twilio (required) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-production-auth-token
TWILIO_PHONE_NUMBER=+233XXXXXXXXX
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── CORS (required) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=https://app.geolandpro.com
ALLOWED_ORIGINS=https://app.geolandpro.com

# ─── Platform ───────────────────────────────────────────────────────────────────
COMMISSION_RATE_PERCENT=4

# ─── AI / OpenRouter (required) ─────────────────────────────────────────────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-replace-with-production-key
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# ─── Brand ───────────────────────────────────────────────────────────────────────
APP_NAME=GeoLand Pro
APP_NAME_SHORT=GLP
APP_TAGLINE=Protecting Land. Building Trust.
APP_DOMAIN=geolandpro.com
APP_COMPANY_NAME=GeoLand Pro Ghana Limited
APP_SUPPORT_EMAIL=support@geolandpro.com
APP_ADDRESS=Accra, Ghana
APP_PHONE=
APP_LOGO_URL=

# ─── Satellite (Google Earth Engine) — optional, warns if unset ────────────────
GOOGLE_EARTH_ENGINE_KEY=

# ─── Error tracking — optional, warns if unset ─────────────────────────────────
SENTRY_DSN=

# ─── Planet Labs (optional) — optional, warns if unset ─────────────────────────
PLANET_LABS_API_KEY=
