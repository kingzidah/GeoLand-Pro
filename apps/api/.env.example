# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL with PostGIS extension enabled
DATABASE_URL=postgresql://postgres:password@localhost:5432/geolandpro

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-64-byte-hex-string-access
JWT_REFRESH_SECRET=replace-with-64-byte-hex-string-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption ──────────────────────────────────────────────────────────────
# 32-byte (AES-256) key, reserved for future field-level encryption of sensitive data
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-32-byte-hex-string

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=geolandpro-documents

# ─── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+233XXXXXXXXX
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Platform ────────────────────────────────────────────────────────────────
COMMISSION_RATE_PERCENT=4
WEB_APP_URL=http://localhost:5173

# ─── AI (OpenRouter) ───────────────────────────────────────────────────────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-replace-with-your-key
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# ─── Brand ───────────────────────────────────────────────────────────────────
# Update these when the app name is finalised — nothing else needs to change
APP_NAME=GeoLand Pro
APP_NAME_SHORT=GLP
APP_TAGLINE=Protecting Land. Building Trust.
APP_DOMAIN=localhost
APP_COMPANY_NAME=GeoLand Pro Ghana Limited
APP_SUPPORT_EMAIL=support@app.local
APP_ADDRESS=Accra, Ghana
APP_PHONE=
APP_LOGO_URL=

# ─── Field encryption / OTP salts ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HASH_SALT=replace-with-32-byte-hex-string
OTP_SALT=replace-with-32-byte-hex-string

# ─── Allowed origins (security middleware) ────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ─── Satellite (Google Earth Engine) ──────────────────────────────────────────
# Optional. When unset, the satellite fetch job logs "pending API key" and
# skips imagery requests until this is configured.
GOOGLE_EARTH_ENGINE_KEY=
